{
  "enabledPlugins": {
    "fundscore-data@fundscore-harness": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/eslint-changed.sh"
          }
        ]
      }
    ]
  }
}
